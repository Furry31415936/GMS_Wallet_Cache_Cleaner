#!/system/bin/sh
# This is the installation script for Magisk modules

# Define variables
OUTFD=$2
ZIPFILE=$3

# UI print function
ui_print() { echo -e "ui_print $1\nui_print" > /proc/self/fd/$OUTFD; }

# Print module name
ui_print "********************************"
ui_print "   GMS Wallet Cache Cleaner     "
ui_print "********************************"

# Extract files
unzip -o "$ZIPFILE" -d $TMPDIR >&2

# Copy files to target directory
cp -af $TMPDIR/* $MODPATH/

# Set permissions
set_perm_recursive $MODPATH 0 0 0755 0644
set_perm $MODPATH/clear.sh 0 0 0755

ui_print "Module installed successfully!"